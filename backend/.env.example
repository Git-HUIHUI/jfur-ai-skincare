# 晶肤AI美肤助手 - 环境变量配置模板
# 复制此文件为 .env 并填入真实值

# ========== 阿里云百炼 (DashScope) ==========
# 用于 Qwen 多模态/文本模型
# 获取地址：https://dashscope.console.aliyun.com/
DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ========== 火山方舟 (Ark) ==========
# 用于 Seedream 4.5 图生图效果模拟
# 获取地址：https://console.volcengine.com/ark/
ARK_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ========== 数据库配置 ==========
# ChromaDB 向量数据库存储路径
CHROMA_DB_PATH=./chroma_db

# ========== 服务配置 ==========
# Uploads 目录的公网地址（Seedream 需要通过 URL 访问上传的图片）
# 开发环境：http://localhost:8001
# 部署环境：你的实际域名（如 https://your-domain.com）
UPLOADS_BASE_URL=http://localhost:8001

# CORS 配置 - 允许的前端访问来源
# 多个来源用逗号分隔
# 开发环境: http://localhost:3000,http://localhost:3001
# 生产环境: https://yourdomain.com
# 或者用 * 表示允许所有来源（不推荐用于生产环境）
CORS_ALLOWED_ORIGINS=*
